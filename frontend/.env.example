# Copy to .env.local and restart `npm run dev`.
#
# Render / production:
#   VITE_API_URL=https://taskmanage-ieni.onrender.com
#
# Local backend only (requests hit localhost:5001):
#   VITE_API_URL=http://localhost:5001
#
# Or omit VITE_API_URL — Vite proxies /api to http://localhost:5001
VITE_API_URL=https://taskmanage-ieni.onrender.com
