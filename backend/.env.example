# Server
PORT=5001
NODE_ENV=development

# MongoDB connection string (Railway MongoDB plugin or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/team-task-manager

# JWT secret — use a long random string in production
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins for CORS (Vercel preview + prod)
CORS_ORIGIN=http://localhost:5173

# Optional: seed first admin (npm run seed:admin)
# ADMIN_NAME=Admin User
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!
